HOST=0.0.0.0
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-west-1.pooler.supabase.com:5432/postgres
DATABASE_SSL=require
DATABASE_POOL_MAX=8
DATABASE_CONNECT_TIMEOUT_MS=60000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_QUERY_TIMEOUT_MS=60000
DATABASE_STATEMENT_TIMEOUT_MS=60000
DATABASE_STARTUP_RETRIES=5
DATABASE_STARTUP_RETRY_DELAY_MS=5000
BACKGROUND_JOBS_FIRST_RUN_DELAY_MS=180000
BACKGROUND_JOBS_INTERVAL_MS=3600000
PUBLIC_APP_URL=https://ai-job-tracker.onrender.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_SUMMARY_MODEL=gpt-5-nano
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM="AI Job Tracker <jobs@ai-job-tracker.com>"
EMAIL_REPLY_TO="you@example.com"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_admin_password
